<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Shoe Market Pro</title>

<style>
body {
    font-family: Arial;
    margin: 0;
    background: #f5f5f5;
}

header {
    background: black;
    color: white;
    padding: 15px;
    text-align: center;
}

.search {
    text-align: center;
    margin: 20px;
}

.search input {
    padding: 10px;
    width: 250px;
    border-radius: 5px;
    border: 1px solid #ccc;
}

.container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
}

.card {
    background: white;
    width: 250px;
    margin: 15px;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 0 10px rgba(0,0,0,0.1);
    text-align: center;
}

.card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
}

.price {
    color: green;
    font-weight: bold;
}

button {
    background: black;
    color: white;
    border: none;
    padding: 10px;
    margin: 5px;
    cursor: pointer;
    border-radius: 5px;
}

.cart {
    position: fixed;
    top: 10px;
    right: 10px;
    background: white;
    padding: 10px;
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(0,0,0,0.2);
}
</style>
</head>

<body>

<header>
    <h1>👟 Shoe Market</h1>
</header>

<div class="search">
    <input type="text" id="search" placeholder="Search shoes..." onkeyup="filterProducts()">
</div>

<div class="cart">
    🛒 Cart: <span id="cart-count">0</span>
</div>

<div class="container" id="products">

<div class="card" data-name="nike air">
    <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff">
    <h3>Nike Air</h3>
    <p class="price">12000 DA</p>
    <button onclick="addToCart('Nike Air')">Add to Cart</button>
    <button onclick="orderWhatsApp('Nike Air')">Order</button>
</div>

<div class="card" data-name="adidas run">
    <img src="https://images.unsplash.com/photo-1519741497674-611481863552">
    <h3>Adidas Run</h3>
    <p class="price">9500 DA</p>
    <button onclick="addToCart('Adidas Run')">Add to Cart</button>
    <button onclick="orderWhatsApp('Adidas Run')">Order</button>
</div>

<div class="card" data-name="puma sport">
    <img src="https://images.unsplash.com/photo-1528701800489-20be3cbb2cfd">
    <h3>Puma Sport</h3>
    <p class="price">8700 DA</p>
    <button onclick="addToCart('Puma Sport')">Add to Cart</button>
    <button onclick="orderWhatsApp('Puma Sport')">Order</button>
</div>

</div>

<script>
let cart = 0;

function addToCart(product) {
    cart++;
    document.getElementById("cart-count").innerText = cart;
}

function orderWhatsApp(product) {
    let phone = "213XXXXXXXXX"; // replace with your number
    let message = "Hello, I want to order: " + product;
    let url = "https://wa.me/" + phone + "?text=" + encodeURIComponent(message);
    window.open(url, "_blank");
}

function filterProducts() {
    let input = document.getElementById("search").value.toLowerCase();
    let cards = document.querySelectorAll(".card");

    cards.forEach(card => {
        let name = card.getAttribute("data-name");
        card.style.display = name.includes(input) ? "block" : "none";
    });
}
</script>

</body>
</html>
